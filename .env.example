# 复制为 .env 后改这些值：cp .env.example .env
# .env 已 gitignore，不会提交。

# 时区(仅容器启动前几毫秒 + `date` 等诊断命令的参考值)。
# 调度实际用的时区由 config 决定(settings.timezone,启动时 applyTimezone() 会覆盖 process.env.TZ,
# 不看这个 env)——查 GET /api/timezone 或启动日志 `[tz] 时区 = ...`;要改用 POST /api/timezone。
TZ=America/Los_Angeles

# Web UI 端口（宿主机）
PORT=7860

# 端口绑定的网卡。默认 0.0.0.0=所有网卡（局域网 <本机IP>:7860 + Tailscale 100.x:7860 都可达；
# 家用机在 NAT 路由器后 → 公网进不来）。部署到有公网 IP 的机器时，改成具体内网/Tailscale IP
# （如本机 Tailscale IP 100.x.x.x）或加防火墙，避免无鉴权服务裸奔公网。
BIND=0.0.0.0

# 宿主机持久化根目录（容器重建不丢）。内部布局固定，无需分别配置：
#   <DATA_ROOT>/db/douyin-rec.db            数据库（含抖音账号 cookie）
#   <DATA_ROOT>/recordings/                 录像/弹幕输出（任务未单独设 outDir 时用）
#   <DATA_ROOT>/config/biliup/cookies.json  biliup B站上传 cookie
DATA_ROOT=./docker-data

# 可选：Discord 通知 webhook（留空则不通知）
DISCORD_WEBHOOK=

# ────────────────────────────────────────────────────────────────────────────
# 以下仅裸跑（不用 docker，直接 `node dist/douyin-rec.mjs ...`）时生效：
# CLI 启动会自动读 <cwd>/.env（Node 内置 process.loadEnvFile，无 .env 则静默跳过）。
# docker 用不到这段——容器内数据根写死在 docker-compose.yml 的 environment 里，不受此文件影响，
# 也不会读到这个 .env（没拷进镜像）。
#
# 数据根（db/recordings/stage/config 全收在这一个目录下）。留空 = 默认 ./output-data。
# 和上面的 DATA_ROOT 是两个不同东西：DATA_ROOT 只给 docker-compose 做卷映射用；
# DOUYIN_REC_ROOT 才是代码真正读的那个变量（裸跑本地开发一般不用改，想自定义再设）。
# DOUYIN_REC_ROOT=./output-data

# 专用 env（优先级比 DOUYIN_REC_ROOT 派生路径更高，可单独覆盖某一项）：
# DOUYIN_REC_DB=./output-data/db/douyin-rec.db
# DOUYIN_REC_OUTPUT=./output-data/recordings
# BILIUP_COOKIE=./output-data/config/biliup/cookies.json
